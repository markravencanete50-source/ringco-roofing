rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Leads: created by the public site (server SDK bypasses these rules,
    // but this blocks any client-side tampering). No public reads.
    match /leads/{doc} {
      allow read: if false;
      allow create: if false; // writes happen via server API (admin SDK)
      allow update, delete: if false;
    }

    // Gallery: anyone can read (public gallery). Only signed-in admins write.
    match /gallery/{doc} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
