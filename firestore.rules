rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin users. A signed-in person may read ONLY their own record
    // (the /admin dashboard uses this to confirm role == "admin").
    // Create/edit users in the Firebase console, never from the client.
    match /users/{userId} {
      allow read: if request.auth != null
                  && resource.data.email == request.auth.token.email;
      allow write: if false;
    }

    // Website leads (contact / "free estimate" form submissions).
    //  - Anyone may CREATE a lead (the public form), but only with a
    //    validated shape and status locked to "new" — so the collection
    //    can't be used as free-form public storage.
    //  - Only a signed-in admin may READ them or UPDATE their status/notes
    //    (only admins have Auth accounts). Leads are never deleted from
    //    the client, so nothing can be silently destroyed.
    match /leads/{leadId} {
      allow create: if request.resource.data.status == 'new'
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() < 120
                    && request.resource.data.phone is string
                    && request.resource.data.phone.size() < 40
                    && request.resource.data['service'] is string
                    && request.resource.data['service'].size() < 120
                    && (!('email' in request.resource.data) || request.resource.data.email.size() < 160)
                    && (!('city' in request.resource.data) || (request.resource.data.city is string && request.resource.data.city.size() < 120))
                    && (!('message' in request.resource.data) || request.resource.data.message.size() < 4000);
      allow read, update: if request.auth != null;
      allow delete: if false;
    }

    // Site settings (e.g. the public "recent storm" banner published from
    // the admin Storm center). Anyone may read — the public site shows the
    // banner — but only a signed-in admin may write.
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Everything else stays fully locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
